# =============================================================================
# Agentic RAG Gym - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# --- LLM Configuration ---
API_BASE_URL=http://localhost:11434/v1
MODEL_NAME=qwen2.5:7b
HF_TOKEN=hf_your_token_here
GROQ_API_KEY=gsk_your_groq_key_here

# --- Database ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=raguser
MYSQL_PASSWORD=changeme_secure_password
MYSQL_DATABASE=agentic_rag_gym

# --- FAISS ---
FAISS_INDEX_DIR=./data/faiss_indices
FAISS_DIMENSION=384

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=7860
LOG_LEVEL=INFO

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Environment ---
ENV_MAX_STEPS=20
ENV_TIMEOUT_SECONDS=300
