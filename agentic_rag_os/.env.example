# Agentic RAG OS — Environment Variables
# Copy this to .env and fill in your values

# ── Server ──────────────────────────────────────────────
RAGAS_HOST=0.0.0.0
RAGAS_PORT=8080
RAGAS_DEBUG=false

# ── Security (REQUIRED) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RAGAS_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── GitHub OAuth (REQUIRED for login) ───────────────────
# Create at: https://github.com/settings/applications/new
# Homepage URL: http://localhost:8080
# Callback URL: http://localhost:8080/api/v1/auth/github/callback
RAGAS_GITHUB_CLIENT_ID=your_github_app_client_id
RAGAS_GITHUB_CLIENT_SECRET=your_github_app_client_secret
RAGAS_GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/github/callback

# ── Frontend ─────────────────────────────────────────────
RAGAS_FRONTEND_URL=http://localhost:8080

# ── Database ─────────────────────────────────────────────
# SQLite (default, great for dev/small teams)
RAGAS_DATABASE_URL=sqlite+aiosqlite:///./agentic_rag_os.db
# PostgreSQL (production)
# RAGAS_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/ragos

# ── Storage limits ───────────────────────────────────────
RAGAS_FREE_TIER_MAX_MB=5
RAGAS_PREMIUM_TIER_MAX_MB=500

# ── LLM (optional — for extended reasoning) ─────────────
RAGAS_LLM_API_BASE=http://localhost:11434/v1
RAGAS_LLM_API_KEY=none
RAGAS_LLM_MODEL=qwen2.5:7b

# ── CORS ─────────────────────────────────────────────────
# RAGAS_ALLOWED_ORIGINS=["http://localhost:8080","https://your-domain.com"]
